<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_gdpr_request_list" model="ir.ui.view">
        <field name="name">gdpr.request.list</field>
        <field name="model">gdpr.request</field>
        <field name="arch" type="xml">
            <list string="Data subject requests"
                decoration-danger="is_overdue"
                decoration-warning="days_remaining &lt;= 5 and days_remaining &gt;= 0 and state not in ['completed','rejected']">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="request_type"/>
                <field name="date_received"/>
                <field name="date_deadline"/>
                <field name="days_remaining" string="Days left"/>
                <field name="assigned_to" widget="many2one_avatar_user"/>
                <field name="is_overdue" invisible="1"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'new'"
                    decoration-warning="state == 'awaiting_id'"
                    decoration-success="state == 'completed'"
                    decoration-danger="state == 'rejected'"
                    decoration-primary="state in ['in_progress','extended']"/>
            </list>
        </field>
    </record>

    <record id="view_gdpr_request_form" model="ir.ui.view">
        <field name="name">gdpr.request.form</field>
        <field name="model">gdpr.request</field>
        <field name="arch" type="xml">
            <form string="Data subject request">
                <header>
                    <button name="action_start" string="Start processing"
                        type="object" class="btn-primary"
                        invisible="state != 'new'"/>
                    <button name="action_complete" string="Mark complete"
                        type="object" class="btn-success"
                        invisible="state not in ['in_progress','awaiting_id','extended']"/>
                    <button name="action_extend" string="Extend (60 days)"
                        type="object"
                        invisible="state not in ['new','in_progress','awaiting_id']"/>
                    <button name="action_reject" string="Reject"
                        type="object" class="btn-danger"
                        invisible="state in ['completed','rejected']"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="new,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="alert alert-danger" role="alert"
                        invisible="not is_overdue">
                        This request is OVERDUE. The 30-day legal deadline has passed.
                    </div>
                    <div class="alert alert-warning" role="alert"
                        invisible="days_remaining &gt; 5 or days_remaining &lt; 0 or state in ['completed','rejected']">
                        Deadline approaching: <field name="days_remaining" readonly="1"/> days remaining.
                    </div>
                    <group>
                        <group string="Request details">
                            <field name="name" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="request_type"/>
                            <field name="channel"/>
                            <field name="date_received"/>
                        </group>
                        <group string="SLA">
                            <field name="date_deadline"/>
                            <field name="days_remaining" string="Days remaining" readonly="1"/>
                            <field name="is_overdue" readonly="1" widget="boolean_toggle"/>
                            <field name="date_extended_deadline" invisible="state != 'extended'"/>
                            <field name="assigned_to" widget="many2one_avatar_user"/>
                        </group>
                    </group>
                    <group string="Identity verification">
                        <field name="identity_verified" widget="boolean_toggle"/>
                        <field name="identity_method" invisible="not identity_verified"/>
                    </group>
                    <notebook>
                        <page string="Request details">
                            <field name="description" placeholder="Describe what the data subject is requesting..."/>
                        </page>
                        <page string="Response">
                            <field name="response_notes" placeholder="Document actions taken and outcome..."/>
                            <field name="date_completed" invisible="state != 'completed'"/>
                            <field name="export_file" filename="export_filename"
                                invisible="request_type not in ['access','portability']"/>
                            <field name="export_filename" invisible="request_type not in ['access','portability']"/>
                        </page>
                        <page string="Rejection" invisible="state != 'rejected'">
                            <field name="rejection_reason"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_gdpr_request_kanban" model="ir.ui.view">
        <field name="name">gdpr.request.kanban</field>
        <field name="model">gdpr.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="request_type"/>
                <field name="days_remaining"/>
                <field name="is_overdue"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="#{record.is_overdue.raw_value ? 'border-danger' : record.days_remaining.raw_value &lt;= 5 ? 'border-warning' : ''}">
                            <field name="name" class="fw-bold"/>
                            <field name="partner_id"/>
                            <field name="request_type" class="text-muted small"/>
                            <div class="mt-2">
                                <span t-if="record.is_overdue.raw_value" class="badge bg-danger">OVERDUE</span>
                                <span t-elif="record.days_remaining.raw_value &lt;= 5" class="badge bg-warning">
                                    <field name="days_remaining"/> days left
                                </span>
                                <span t-else="" class="text-muted small">
                                    <field name="days_remaining"/> days left
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_gdpr_request" model="ir.actions.act_window">
        <field name="name">Data subject requests</field>
        <field name="res_model">gdpr.request</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_open': 1}</field>
    </record>

</odoo>
