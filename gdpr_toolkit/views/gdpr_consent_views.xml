<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_gdpr_consent_list" model="ir.ui.view">
        <field name="name">gdpr.consent.list</field>
        <field name="model">gdpr.consent</field>
        <field name="arch" type="xml">
            <list string="Consent records" decoration-muted="state == 'withdrawn'" decoration-warning="state == 'expired'">
                <field name="partner_id"/>
                <field name="purpose"/>
                <field name="legal_basis"/>
                <field name="channel"/>
                <field name="date_consent"/>
                <field name="date_expiry"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'active'"
                    decoration-warning="state == 'expired'"
                    decoration-danger="state == 'withdrawn'"/>
            </list>
        </field>
    </record>

    <record id="view_gdpr_consent_form" model="ir.ui.view">
        <field name="name">gdpr.consent.form</field>
        <field name="model">gdpr.consent</field>
        <field name="arch" type="xml">
            <form string="Consent record">
                <header>
                    <button name="action_withdraw" string="Withdraw consent"
                        type="object" class="btn-danger"
                        invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="active,withdrawn,expired"/>
                </header>
                <sheet>
                    <group>
                        <group string="Who &amp; what">
                            <field name="partner_id"/>
                            <field name="purpose"/>
                            <field name="purpose_other" invisible="purpose != 'other'"/>
                            <field name="legal_basis"/>
                        </group>
                        <group string="How &amp; when">
                            <field name="channel"/>
                            <field name="date_consent"/>
                            <field name="date_expiry"/>
                            <field name="ip_address"/>
                            <field name="version"/>
                        </group>
                    </group>
                    <group string="Withdrawal" invisible="state != 'withdrawn'">
                        <field name="date_withdrawn"/>
                        <field name="withdrawn_by"/>
                    </group>
                    <group string="Proof">
                        <field name="proof" placeholder="URL, email ID, or document reference"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_gdpr_consent_search" model="ir.ui.view">
        <field name="name">gdpr.consent.search</field>
        <field name="model">gdpr.consent</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="purpose"/>
                <filter string="Active" name="active" domain="[('state','=','active')]"/>
                <filter string="Withdrawn" name="withdrawn" domain="[('state','=','withdrawn')]"/>
                <filter string="Expired" name="expired" domain="[('state','=','expired')]"/>
                <group expand="0" string="Group by">
                    <filter string="Purpose" name="group_purpose" context="{'group_by': 'purpose'}"/>
                    <filter string="Legal basis" name="group_basis" context="{'group_by': 'legal_basis'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gdpr_consent" model="ir.actions.act_window">
        <field name="name">Consent records</field>
        <field name="res_model">gdpr.consent</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_gdpr_consent_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>
