<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_gdpr_audit_log_list" model="ir.ui.view">
        <field name="name">gdpr.audit.log.list</field>
        <field name="model">gdpr.audit.log</field>
        <field name="arch" type="xml">
            <list string="Audit trail" create="false" delete="false" edit="false">
                <field name="date"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="action" widget="badge"
                    decoration-danger="action in ['data_deleted','breach_created','breach_dpa_notified']"
                    decoration-warning="action in ['consent_withdrawn','dsr_rejected','retention_delete']"
                    decoration-success="action in ['dsr_completed','consent_created']"
                    decoration-info="action in ['data_exported','data_accessed']"/>
                <field name="model_name"/>
                <field name="record_id"/>
                <field name="description"/>
                <field name="ip_address"/>
            </list>
        </field>
    </record>

    <record id="view_gdpr_audit_log_search" model="ir.ui.view">
        <field name="name">gdpr.audit.log.search</field>
        <field name="model">gdpr.audit.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="description"/>
                <field name="model_name"/>
                <filter string="Today" name="today"
                    domain="[('date','&gt;=', datetime.datetime.combine(datetime.date.today(), datetime.time(0,0,0)))]"/>
                <filter string="This week" name="week"
                    domain="[('date','&gt;=',(datetime.date.today()-datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter string="Consents" name="consent"
                    domain="[('action','in',['consent_created','consent_withdrawn'])]"/>
                <filter string="DSRs" name="dsr"
                    domain="[('action','like','dsr_')]"/>
                <filter string="Breaches" name="breach"
                    domain="[('action','like','breach_')]"/>
                <filter string="Deletions" name="deletion"
                    domain="[('action','in',['data_deleted','retention_delete'])]"/>
                <group expand="0" string="Group by">
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Action" name="group_action" context="{'group_by': 'action'}"/>
                    <filter string="Model" name="group_model" context="{'group_by': 'model_name'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gdpr_audit_log" model="ir.actions.act_window">
        <field name="name">Audit trail</field>
        <field name="res_model">gdpr.audit.log</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_gdpr_audit_log_search"/>
        <field name="context">{'create': False}</field>
    </record>

</odoo>
