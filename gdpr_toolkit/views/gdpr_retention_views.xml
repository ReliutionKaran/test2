<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Retention rules list -->
    <record id="view_gdpr_retention_list" model="ir.ui.view">
        <field name="name">gdpr.retention.rule.list</field>
        <field name="model">gdpr.retention.rule</field>
        <field name="arch" type="xml">
            <list string="Retention rules">
                <field name="name"/>
                <field name="model_id"/>
                <field name="date_field"/>
                <field name="retention_days" string="Keep (days)"/>
                <field name="action" widget="badge"/>
                <field name="last_run"/>
                <field name="records_processed"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_gdpr_retention_form" model="ir.ui.view">
        <field name="name">gdpr.retention.rule.form</field>
        <field name="model">gdpr.retention.rule</field>
        <field name="arch" type="xml">
            <form string="Retention rule">
                <header>
                    <button name="action_run_now" string="Run now"
                        type="object" class="btn-primary"
                        groups="gdpr_toolkit.group_gdpr_admin"/>
                </header>
                <sheet>
                    <group>
                        <group string="Rule definition">
                            <field name="name"/>
                            <field name="active" widget="boolean_toggle"/>
                            <field name="model_id"/>
                            <field name="date_field"
                                domain="[('model_id','=',model_id),('ttype','in',['date','datetime'])]"/>
                            <field name="retention_days"/>
                            <field name="action"/>
                            <field name="domain" placeholder="[] for all records"/>
                        </group>
                        <group string="Last run">
                            <field name="last_run" readonly="1"/>
                            <field name="records_processed" readonly="1"/>
                        </group>
                    </group>
                    <group string="Anonymisation fields" invisible="action != 'anonymise'">
                        <field name="fields_to_anonymise" widget="many2many_tags"
                            domain="[('model_id','=',model_id),('ttype','in',['char','text','email','phone'])]"/>
                        <p class="text-muted small">Leave blank to anonymise all char/text/email/phone fields.</p>
                    </group>
                    <group string="Legal justification">
                        <field name="legal_basis" placeholder="Why is this retention period appropriate?"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_gdpr_retention" model="ir.actions.act_window">
        <field name="name">Retention rules</field>
        <field name="res_model">gdpr.retention.rule</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
