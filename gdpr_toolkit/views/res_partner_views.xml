<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_gdpr_form" model="ir.ui.view">
        <field name="name">res.partner.gdpr.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Smart buttons -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_gdpr_consents"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-check-circle"
                    groups="gdpr_toolkit.group_gdpr_auditor">
                    <field name="gdpr_consent_count" widget="statinfo" string="Consents"/>
                </button>
                <button name="action_view_gdpr_requests"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-file-text"
                    groups="gdpr_toolkit.group_gdpr_auditor">
                    <field name="gdpr_request_count" widget="statinfo" string="DSRs"/>
                </button>
            </xpath>

            <!-- GDPR tab inside the notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="GDPR" name="gdpr_tab"
                    groups="gdpr_toolkit.group_gdpr_auditor">
                    <group>
                        <group string="GDPR flags">
                            <field name="gdpr_do_not_contact" widget="boolean_toggle"/>
                            <field name="gdpr_erasure_requested" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <separator string="Consent history"/>
                    <field name="gdpr_consent_ids" mode="list" readonly="1"
                        context="{'default_partner_id': active_id}">
                        <list>
                            <field name="purpose"/>
                            <field name="legal_basis"/>
                            <field name="channel"/>
                            <field name="date_consent"/>
                            <field name="state" widget="badge"
                                decoration-success="state == 'active'"
                                decoration-danger="state == 'withdrawn'"
                                decoration-warning="state == 'expired'"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
