<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level menu -->
    <menuitem id="menu_gdpr_root"
        name="GDPR"
        sequence="90"
        web_icon="gdpr_toolkit,static/description/icon.png"
        groups="gdpr_toolkit.group_gdpr_auditor"/>

    <!-- Operations -->
    <menuitem id="menu_gdpr_operations"
        name="Operations"
        parent="menu_gdpr_root"
        sequence="10"/>

    <menuitem id="menu_gdpr_consent"
        name="Consent records"
        parent="menu_gdpr_operations"
        action="action_gdpr_consent"
        sequence="10"/>

    <menuitem id="menu_gdpr_request"
        name="Data subject requests"
        parent="menu_gdpr_operations"
        action="action_gdpr_request"
        sequence="20"/>

    <menuitem id="menu_gdpr_breach"
        name="Data breaches"
        parent="menu_gdpr_operations"
        action="action_gdpr_breach"
        sequence="30"/>

    <!-- Compliance -->
    <menuitem id="menu_gdpr_compliance"
        name="Compliance"
        parent="menu_gdpr_root"
        sequence="20"/>

    <menuitem id="menu_gdpr_register"
        name="Processing register (Art. 30)"
        parent="menu_gdpr_compliance"
        action="action_gdpr_register"
        sequence="10"/>

    <menuitem id="menu_gdpr_audit"
        name="Audit trail"
        parent="menu_gdpr_compliance"
        action="action_gdpr_audit_log"
        sequence="20"/>

    <!-- Configuration -->
    <menuitem id="menu_gdpr_config"
        name="Configuration"
        parent="menu_gdpr_root"
        sequence="30"
        groups="gdpr_toolkit.group_gdpr_admin"/>

    <menuitem id="menu_gdpr_retention"
        name="Retention rules"
        parent="menu_gdpr_config"
        action="action_gdpr_retention"
        sequence="10"/>

    <menuitem id="menu_gdpr_data_category"
        name="Data categories"
        parent="menu_gdpr_config"
        action="action_gdpr_data_category"
        sequence="20"/>

</odoo>
