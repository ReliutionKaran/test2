<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_gdpr_audit_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>GDPR Audit Trail Report</h2>
                    <p class="text-muted">Generated: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %B %Y %H:%M')"/></p>
                    <p class="text-muted">Company: <t t-esc="company.name"/></p>

                    <table class="table table-sm table-striped mt-4">
                        <thead>
                            <tr>
                                <th>Date / time</th>
                                <th>User</th>
                                <th>Action</th>
                                <th>Model</th>
                                <th>Description</th>
                                <th>IP address</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="log">
                                <tr>
                                    <td><t t-esc="log.date"/></td>
                                    <td><t t-esc="log.user_id.name"/></td>
                                    <td><t t-esc="log.action"/></td>
                                    <td><t t-esc="log.model_name"/></td>
                                    <td><t t-esc="log.description"/></td>
                                    <td><t t-esc="log.ip_address or ''"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <p class="mt-4 text-muted small">
                        This audit trail is tamper-evident. Records cannot be modified or deleted.
                        Total records: <t t-esc="len(docs)"/>
                    </p>
                </div>
            </t>
        </t>
    </template>

    <record id="action_report_gdpr_audit" model="ir.actions.report">
        <field name="name">GDPR Audit Trail</field>
        <field name="model">gdpr.audit.log</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gdpr_toolkit.report_gdpr_audit_document</field>
        <field name="report_file">gdpr_toolkit.report_gdpr_audit_document</field>
        <field name="print_report_name">'GDPR Audit Trail - %s' % (context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d'))</field>
        <field name="binding_model_id" ref="model_gdpr_audit_log"/>
        <field name="binding_type">report</field>
        <field name="groups_id" eval="[(4, ref('group_gdpr_auditor'))]"/>
    </record>

</odoo>
