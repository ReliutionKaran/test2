<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_gdpr_dsr_export_wizard" model="ir.ui.view">
        <field name="name">gdpr.dsr.export.wizard.form</field>
        <field name="model">gdpr.dsr.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export personal data">
                <group>
                    <field name="request_id"/>
                    <field name="partner_id" readonly="1"/>
                    <field name="export_format" widget="radio"/>
                </group>
                <group string="Include data from">
                    <field name="include_contacts" widget="boolean_toggle"/>
                    <field name="include_crm" widget="boolean_toggle"/>
                    <field name="include_sales" widget="boolean_toggle"/>
                    <field name="include_invoices" widget="boolean_toggle"/>
                    <field name="include_helpdesk" widget="boolean_toggle"/>
                </group>
                <footer>
                    <button name="action_export" string="Generate export"
                        type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_gdpr_dsr_export_wizard" model="ir.actions.act_window">
        <field name="name">Export personal data</field>
        <field name="res_model">gdpr.dsr.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
